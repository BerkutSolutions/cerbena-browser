{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cerbena Browser",
  "version": "1.1.5",
  "identifier": "dev.cerbena.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Cerbena",
        "url": "index.html",
        "decorations": false,
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "category": "Network",
    "shortDescription": "Isolated browser profiles with controlled link routing and network policies.",
    "longDescription": "Cerbena Browser provides isolated browser profiles, launcher-managed runtime controls, and explicit network policy enforcement for controlled desktop browsing sessions.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
